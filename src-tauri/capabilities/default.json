{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "/tmp/**" },
        { "path": "/var/folders/**" },
        { "path": "$TEMP/**" },
        { "path": "$LOCALDATA/**" }
      ]
    },
    "dialog:default"
  ]
}
